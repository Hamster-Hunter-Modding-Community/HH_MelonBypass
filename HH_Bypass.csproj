<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net6.0</TargetFramework>
    <AssemblyName>HH_Bypass</AssemblyName>
    <RootNamespace>HH_Bypass</RootNamespace>
    <Nullable>disable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <SuppressTfmSupportBuildWarnings>true</SuppressTfmSupportBuildWarnings>
    <!--
      Uncomment to auto-deploy after every build:
    <OutputPath>C:\Program Files (x86)\Steam\steamapps\common\Hamster Hunter\BepInEx\plugins\HH_Bypass\</OutputPath>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <CopyLocalLockFileAssemblies>false</CopyLocalLockFileAssemblies>
    -->
  </PropertyGroup>

  <ItemGroup>
    <!--
      BepInEx 6 IL2CPP — hosted on nuget.bepinex.dev (NOT nuget.org).
      The nuget.config file in this folder adds that feed automatically.
    -->
    <PackageReference Include="BepInEx.Unity.IL2CPP" Version="6.0.0-be.755" />
  </ItemGroup>

  <!--
    Game assemblies — generated by BepInEx on first launch in:
      BepInEx\interop\
    Adjust the path below if your Steam library is elsewhere.
  -->
  <PropertyGroup>
    <GameInteropPath Condition="'$(GameInteropPath)'==''">C:\Program Files (x86)\Steam\steamapps\common\Hamster Hunter\BepInEx\interop</GameInteropPath>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="Assembly-CSharp">
      <HintPath>$(GameInteropPath)\Assembly-CSharp.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UnityEngine.CoreModule">
      <HintPath>$(GameInteropPath)\UnityEngine.CoreModule.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

</Project>
